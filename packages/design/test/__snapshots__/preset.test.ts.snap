.bg-secondary{--un-bg-opacity:1;background-color:rgb(253 253 253 / var(--un-bg-opacity));}
.dark .bg-secondary{--un-bg-opacity:1;background-color:rgb(16 16 16 / var(--un-bg-opacity));}
.bg-tooltip{background-color:rgb(255 255 255 / 0.75);--un-backdrop-blur:blur(8px);-webkit-backdrop-filter:var(--un-backdrop-blur) var(--un-backdrop-brightness) var(--un-backdrop-contrast) var(--un-backdrop-grayscale) var(--un-backdrop-hue-rotate) var(--un-backdrop-invert) var(--un-backdrop-opacity) var(--un-backdrop-saturate) var(--un-backdrop-sepia);backdrop-filter:var(--un-backdrop-blur) var(--un-backdrop-brightness) var(--un-backdrop-contrast) var(--un-backdrop-grayscale) var(--un-backdrop-hue-rotate) var(--un-backdrop-invert) var(--un-backdrop-opacity) var(--un-backdrop-saturate) var(--un-backdrop-sepia);}
.btn-action:hover{--un-bg-opacity:0.07;background-color:rgb(136 136 136 / var(--un-bg-opacity));opacity:1;}
.btn-icon-square:hover{--un-bg-opacity:0.07;background-color:rgb(136 136 136 / var(--un-bg-opacity));opacity:1;}
.btn-primary:hover{--un-bg-opacity:1;background-color:rgb(73 131 62 / var(--un-bg-opacity));}
.pad-safe{padding-left:env(safe-area-inset-left);padding-right:env(safe-area-inset-right);padding-top:env(safe-area-inset-top);padding-bottom:env(safe-area-inset-bottom);}
.text-micro{font-size:10px;line-height:1.4;}
.color-scale-critical{--un-text-opacity:1;color:rgb(185 28 28 / var(--un-text-opacity));}
.dark .color-scale-critical{--un-text-opacity:1;color:rgb(252 165 165 / var(--un-text-opacity));}
.color-scale-low{--un-text-opacity:1;color:rgb(77 124 15 / var(--un-text-opacity));}
.dark .color-scale-low{--un-text-opacity:1;color:rgb(190 242 100 / var(--un-text-opacity));--un-saturate:saturate(0.75);filter:var(--un-blur) var(--un-brightness) var(--un-contrast) var(--un-drop-shadow) var(--un-grayscale) var(--un-hue-rotate) var(--un-invert) var(--un-saturate) var(--un-sepia);}
.dark .badge-muted,
.dark .color-muted{--un-text-opacity:1;color:rgb(163 163 163 / var(--un-text-opacity));}
.color-active{--un-text-opacity:1;color:rgb(73 131 62 / var(--un-text-opacity));}
.dark .color-active{--un-text-opacity:1;color:rgb(168 207 150 / var(--un-text-opacity));}
.color-base{--un-text-opacity:1;color:rgb(38 38 38 / var(--un-text-opacity));}
.dark .color-base{--un-text-opacity:1;color:rgb(229 229 229 / var(--un-text-opacity));}
.color-faint,
.dark .color-faint{--un-text-opacity:1;color:rgb(115 115 115 / var(--un-text-opacity));}
.color-muted{--un-text-opacity:1;color:rgb(82 82 82 / var(--un-text-opacity));}
.dark .btn-icon-square,
.dark .op-fade{opacity:0.55;}
.op-fade{opacity:0.65;}
.dark .op-mute{opacity:0.25;}
.op-mute{opacity:0.3;}
.btn-action:focus-visible{--un-ring-width:2px;--un-ring-offset-shadow:var(--un-ring-inset) 0 0 0 var(--un-ring-offset-width) var(--un-ring-offset-color);--un-ring-shadow:var(--un-ring-inset) 0 0 0 calc(var(--un-ring-width) + var(--un-ring-offset-width)) var(--un-ring-color);box-shadow:var(--un-ring-offset-shadow), var(--un-ring-shadow), var(--un-shadow);--un-ring-color:rgb(91 149 68 / 0.4);}
.btn-icon-square:focus-visible{--un-ring-width:2px;--un-ring-offset-shadow:var(--un-ring-inset) 0 0 0 var(--un-ring-offset-width) var(--un-ring-offset-color);--un-ring-shadow:var(--un-ring-inset) 0 0 0 calc(var(--un-ring-width) + var(--un-ring-offset-width)) var(--un-ring-color);box-shadow:var(--un-ring-offset-shadow), var(--un-ring-shadow), var(--un-shadow);--un-ring-color:rgb(91 149 68 / 0.4);}
.btn-primary:focus-visible{--un-ring-width:2px;--un-ring-offset-shadow:var(--un-ring-inset) 0 0 0 var(--un-ring-offset-width) var(--un-ring-offset-color);--un-ring-shadow:var(--un-ring-inset) 0 0 0 calc(var(--un-ring-width) + var(--un-ring-offset-width)) var(--un-ring-color);box-shadow:var(--un-ring-offset-shadow), var(--un-ring-shadow), var(--un-shadow);--un-ring-color:rgb(91 149 68 / 0.4);}
/* layer: default */
.bg-primary{--un-bg-opacity:1;background-color:rgb(73 131 62 / var(--un-bg-opacity));}
.text-primary-600{--un-text-opacity:1;color:rgb(73 131 62 / var(--un-text-opacity));}
.text-success-500{--un-text-opacity:1;color:rgb(18 183 106 / var(--un-text-opacity));}
.text-warning-700{--un-text-opacity:1;color:rgb(181 71 8 / var(--un-text-opacity));}"
`;
