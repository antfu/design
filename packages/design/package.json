  "homepage": "https://github.com/antfu/design#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antfu/design.git",
    "directory": "packages/design"
  },
  "bugs": "https://github.com/antfu/design/issues",
  "keywords": [
    "unocss",
    "unocss-preset",
    "vue",
    "design-system",
    "components",
    "devtools",
    "antfu"
  ],
  "sideEffects": false,
  "exports": {
